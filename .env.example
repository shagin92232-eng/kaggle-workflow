# ============ REQUIRED ============
TELEGRAM_BOT_TOKEN=
OPENROUTER_API_KEY=
YOUTUBE_DATA_API_KEY=

# Path to Google service-account JSON file (for Sheets logging)
GOOGLE_SHEETS_CREDENTIALS_JSON=credentials/google_sheets_credentials.json
# The spreadsheet to log into (create a sheet, share it with the service
# account email, then paste the ID from the sheet URL here)
GOOGLE_SHEETS_SPREADSHEET_ID=

# ============ LLM ============
# OpenRouter model — ':free' suffix = free tier (rate-limited ~50 req/day).
# May be a comma-separated fallback list, tried in order when a model is
# unavailable or rate-limited (free models come and go — see the current
# list at https://openrouter.ai/models?fmt=cards&max_price=0).
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free,meta-llama/llama-3.3-70b-instruct:free,nvidia/nemotron-3-super-120b-a12b:free

# ============ OPTIONAL TREND APIS (skipped automatically if empty) ============
TIKTOK_API_KEY=
FACEBOOK_API_KEY=
INSTAGRAM_API_KEY=

# ============ WHISPER (transcription) ============
# local  = run faster-whisper on this machine (CPU ok, slower)
# remote = call the Kaggle/Lightning/HF FastAPI endpoint below
WHISPER_MODE=local
WHISPER_MODEL=small
WHISPER_REMOTE_URL=

# ============ LTX-2 (optional B-roll generation, remote only) ============
LTX2_REMOTE_URL=

# ============ KAGGLE (one-time model download + persisted dataset) ============
KAGGLE_USERNAME=
KAGGLE_KEY=

# ============ YOUTUBE DOWNLOAD ============
# Netscape-format cookies file so YouTube doesn't block downloads as a bot.
# Export with a "Cookie Editor"-style browser extension while logged in to
# youtube.com, save as credentials/youtube_cookies.txt. Relative paths are
# resolved from the project root.
YTDLP_COOKIES_FILE=credentials/youtube_cookies.txt

# ============ PIPELINE TUNING ============
MAX_CLIPS_PER_VIDEO=8
CLIP_MIN_SECONDS=15
CLIP_MAX_SECONDS=60
WORK_DIR=data/jobs
MUSIC_LIBRARY_DIR=music/library
OVERLAY_LIBRARY_DIR=assets/overlays
