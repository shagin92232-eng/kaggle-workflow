# ============ REQUIRED ============
TELEGRAM_BOT_TOKEN=
OPENROUTER_API_KEY=
YOUTUBE_DATA_API_KEY=

# Path to Google service-account JSON file (for Sheets logging)
GOOGLE_SHEETS_CREDENTIALS_JSON=credentials/google_sheets_credentials.json
# The spreadsheet to log into (create a sheet, share it with the service
# account email, then paste the ID from the sheet URL here)
GOOGLE_SHEETS_SPREADSHEET_ID=

# ============ LLM ============
# Qwen3 via OpenRouter — ':free' suffix = free tier (rate-limited ~50 req/day).
# Remove ':free' to use the paid tier for higher limits.
OPENROUTER_MODEL=qwen/qwen3-235b-a22b:free

# ============ OPTIONAL TREND APIS (skipped automatically if empty) ============
TIKTOK_API_KEY=
FACEBOOK_API_KEY=
INSTAGRAM_API_KEY=

# ============ WHISPER (transcription) ============
# local  = run faster-whisper on this machine (CPU ok, slower)
# remote = call the Kaggle/Lightning/HF FastAPI endpoint below
WHISPER_MODE=local
WHISPER_MODEL=small
WHISPER_REMOTE_URL=

# ============ LTX-2 (optional B-roll generation, remote only) ============
LTX2_REMOTE_URL=

# ============ KAGGLE (one-time model download + persisted dataset) ============
KAGGLE_USERNAME=
KAGGLE_KEY=

# ============ PIPELINE TUNING ============
MAX_CLIPS_PER_VIDEO=8
CLIP_MIN_SECONDS=15
CLIP_MAX_SECONDS=60
WORK_DIR=data/jobs
MUSIC_LIBRARY_DIR=music/library
OVERLAY_LIBRARY_DIR=assets/overlays
